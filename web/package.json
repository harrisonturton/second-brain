{
  "name": "second-brain-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-desktop/main.js",
  "scripts": {
    "dev": "npm run dev:app-web",
    "dev:app-web": "vite --mode app-web",
    "dev:app-desktop": "concurrently -k \"npm:dev:app-desktop:renderer\" \"npm:dev:app-desktop:main\" \"npm:dev:app-desktop:launch\"",
    "dev:app-desktop:renderer": "vite --mode app-desktop",
    "dev:app-desktop:main": "tsc -p tsconfig.electron.json --watch",
    "dev:app-desktop:launch": "wait-on tcp:5173 file:dist-desktop/main.js && VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "npm run build:app-web",
    "build:app-web": "tsc -b && vite build --mode app-web",
    "build:app-desktop": "npm run build:app-desktop:renderer && npm run build:app-desktop:main && electron-builder",
    "build:app-desktop:renderer": "vite build --mode app-desktop",
    "build:app-desktop:main": "tsc -p tsconfig.electron.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:app-web": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "styled-components": "^6.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.secondbrain.app",
    "files": [
      "dist/**/*",
      "dist-desktop/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
